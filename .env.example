# Email notifications for contact form submissions via Web3Forms (https://web3forms.com)
# Free: 250 submissions/month, no domain verification needed — just sign up with your Gmail
# Steps: 1) Go to web3forms.com  2) Enter metrilabcl@gmail.com  3) Copy the access key here
WEB3FORMS_ACCESS_KEY=

# Optional webhook to receive lead data as JSON POST
CONTACT_WEBHOOK_URL=

# Canonical site URL — used in sitemap, structured data, and Open Graph
# Set to https://bvyon-marketing.cl in production
NEXT_PUBLIC_SITE_URL=https://bvyon-marketing.cl
