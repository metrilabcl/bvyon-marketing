# Email delivery via Resend (https://resend.com)
# Required to send contact form submissions by email
RESEND_API_KEY=

# Destination email for contact form leads
# Defaults to metrilabcl@gmail.com if not set
CONTACT_EMAIL=

# Optional webhook to receive lead data as JSON POST
CONTACT_WEBHOOK_URL=

# Canonical site URL — used in sitemap, structured data, and Open Graph
# Set to https://bvyon-marketing.cl in production
NEXT_PUBLIC_SITE_URL=https://bvyon-marketing.cl
